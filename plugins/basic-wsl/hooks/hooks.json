{
  "description": "在 Codex 要求權限或停止時自動播放 WSL 提示音",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Playing permission request notification sound",
            "command": "paplay \"${PLUGIN_ROOT}/audios/notification.wav\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Playing task completion notification sound",
            "command": "paplay \"${PLUGIN_ROOT}/audios/stop.wav\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

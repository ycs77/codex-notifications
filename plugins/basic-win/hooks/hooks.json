{
  "description": "在 Codex 要求權限或停止時自動播放 Windows 提示音",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Playing permission request notification sound",
            "command": "powershell.exe -NoProfile -Command '$p=Join-Path $env:PLUGIN_ROOT \"audios/notification.wav\"; $p=(Resolve-Path -LiteralPath $p).ProviderPath; [System.Media.SoundPlayer]::new($p).PlaySync()'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Playing task completion notification sound",
            "command": "powershell.exe -NoProfile -Command '$p=Join-Path $env:PLUGIN_ROOT \"audios/stop.wav\"; $p=(Resolve-Path -LiteralPath $p).ProviderPath; [System.Media.SoundPlayer]::new($p).PlaySync()'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
